{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://khatabook-backend-2.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://khatabook-backend-2.onrender.com/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}